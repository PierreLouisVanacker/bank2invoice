# Database
DATABASE_URL=sqlite:///data/db.sqlite

# Stockage
PDFS_DIR=data/pdfs
FACTURES_DIR=data/factures

# LLM provider : "ollama" ou "anthropic"
LLM_PROVIDER=ollama

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Anthropic (optionnel, si LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# LaTeX
LATEX_BINARY=xelatex

# Auth : génère un secret unique avec :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change_me_avec_un_secret_genere_aleatoirement_au_moins_32_chars

# App
DEBUG=true
